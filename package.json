{
  "name": "atherum",
  "version": "0.1.0",
  "private": true,
  "description": "Collective intelligence engine — synthetic social systems for predictive simulation and deliberative evaluation",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "db:generate": "pnpm --filter @atherum/store drizzle-kit generate",
    "db:migrate": "pnpm --filter @atherum/store drizzle-kit migrate",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "pnpm@9.0.0",
  "dependencies": {
    "@ai-sdk/openai": "^3.0.48",
    "@convex-dev/agent": "^0.6.1",
    "@convex-dev/crons": "^0.2.0",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/workpool": "^0.4.6",
    "@mzedstudio/llm-cache": "^0.1.0",
    "ai": "^6.0.140",
    "convex": "^1.34.1",
    "convex-helpers": "^0.1.114",
    "openai": "^4.70.0"
  }
}
