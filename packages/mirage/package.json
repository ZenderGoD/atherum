{
  "name": "@atherum/mirage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./review-deps": {
      "types": "./dist/review-deps.d.ts",
      "import": "./dist/review-deps.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/review-deps.ts --format esm --dts",
    "dev": "tsup src/index.ts src/review-deps.ts --format esm --dts --watch"
  },
  "dependencies": {
    "@atherum/core": "workspace:*",
    "openai": "^4.70.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
