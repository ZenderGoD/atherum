# Atherum — Environment Configuration
# Copy to .env and fill in values

# API Server
PORT=3100
NODE_ENV=development

# Postgres (Drizzle ORM)
DATABASE_URL=postgresql://atherum:atherum_dev@localhost:5432/atherum

# Redis
REDIS_URL=redis://localhost:6379

# Neo4j (Atlas knowledge graphs)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=atherum_dev

# OASIS Worker
OASIS_WORKER_URL=http://localhost:8100

# LLM Providers (via OpenRouter or direct)
OPENROUTER_API_KEY=
# Or direct provider keys:
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Default LLM model for agent responses
DEFAULT_LLM_MODEL=anthropic/claude-sonnet-4-20250514

# Embedding model
EMBEDDING_MODEL=openai/text-embedding-3-small

# Web search (for persona generation grounding)
TAVILY_API_KEY=

# Auth
API_KEY_SECRET=change-me-in-production

# Cost governance
DEFAULT_SESSION_BUDGET_USD=5.00
DEFAULT_MONTHLY_BUDGET_USD=100.00

# Agent roster
DAILY_ROSTER_SIZE=15
ROSTER_GENERATION_CRON=0 6 * * *
