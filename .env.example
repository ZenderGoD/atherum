# Atherum — Environment Configuration
# Copy to .env and fill in values

# API Server
PORT=4000
NODE_ENV=development

# Convex (run `npx convex dev` in apps/api/ to get your URL)
CONVEX_URL=

# LLM Provider (via OpenRouter)
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_NAME=google/gemini-3.1-flash-lite-preview:nitro

# OASIS Worker (Python social simulation)
OASIS_WORKER_URL=http://localhost:4001

# Cost governance
DEFAULT_SESSION_BUDGET_USD=5.00
DEFAULT_MONTHLY_BUDGET_USD=100.00
